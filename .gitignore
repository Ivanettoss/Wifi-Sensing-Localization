# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/

# Environments
.venv/
env/
venv/
*.egg-info/

# Data: keep folders, ignore contents
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

*.mat
*.npy
*.npz

# Model checkpoints
*.pt
*.pth
*.ckpt
outputs/models/*
!outputs/models/.gitkeep

# Generated split files
outputs/splits/*.npz
!outputs/splits/.gitkeep

# Detailed experiment logs
outputs/logs/*_metrics.json
outputs/logs/*_history.csv

# Ignore generic CSV files, but keep final summary CSV files
*.csv
!outputs/logs/fingerprint_classification_full_random_results.csv
!outputs/logs/fingerprint_classification_ordered_k_results.csv

# Reports / results
results/figures/*
!results/figures/.gitkeep

results/tables/*
!results/tables/.gitkeep

# OS / IDE
.DS_Store
.vscode/
.idea/